{
  "compilerOptions": {
    "lib": ["DOM", "ES2022", "ES2023.Array"],
    "jsx": "react-jsx",
    "target": "ESNext",
    "noEmit": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,

    /* modules */
    "module": "ESNext",
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,

    /* path aliases */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* type checking */
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src"]
}
