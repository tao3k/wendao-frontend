{
  "name": "qianji-studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "rspack dev",
    "build": "rspack build && node scripts/check-build-size.mjs",
    "build:mermaid-report": "node scripts/mermaid-bundle-report.mjs",
    "generate:flight-client": "node scripts/generate-flight-client.mjs",
    "preview": "rspack preview",
    "test": "vitest run",
    "test:hotspot-perf": "rm -f \"${PRJ_CACHE_HOME}/agent/tmp/wendao_frontend_hotspot_perf_traces.json\" && QIANJI_WRITE_HOTSPOT_PERF_REPORT=1 vitest run --no-file-parallelism src/components/SearchBar/__tests__/SearchInputHeader.test.tsx src/components/SearchBar/__tests__/SearchSuggestionsPanel.test.tsx src/components/SearchBar/__tests__/SearchResultsPanel.test.tsx src/components/SearchBar/__tests__/useSearchDerivedState.test.tsx src/components/SearchBar/__tests__/useSearchBarControllerPresentation.test.tsx src/components/SearchBar/__tests__/SearchBarHotspotPerf.test.tsx src/components/SearchBar/interface/autocomplete/__tests__/useSearchAutocompleteInterfacePerf.test.tsx src/components/ZenSearch/__tests__/ZenSearchWorkspace.test.tsx src/components/ZenSearch/__tests__/useZenSearchPreview.test.tsx src/App.test.tsx",
    "test:live-gateway": "RUN_LIVE_GATEWAY_TEST=1 STUDIO_LIVE_GATEWAY_URL=${STUDIO_LIVE_GATEWAY_URL:-http://127.0.0.1:9517} vitest run src/api/liveGateway.test.ts",
    "test:live-flight-perf": "RUN_LIVE_GATEWAY_TEST=1 STUDIO_LIVE_GATEWAY_URL=${STUDIO_LIVE_GATEWAY_URL:-http://127.0.0.1:9517} vitest run src/api/liveFlightSearchPerf.test.ts"
  },
  "dependencies": {
    "@algolia/autocomplete-core": "^1.19.8",
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-web": "2.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-oniguruma": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "apache-arrow": "^21.1.0",
    "beautiful-mermaid": "^1.1.3",
    "bpmn-js": "^18.13.0",
    "framer-motion": "^12.35.0",
    "katex": "^0.16.35",
    "lucide-react": "^0.577.0",
    "postprocessing": "^6.38.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.4",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "smol-toml": "^1.6.0",
    "three": "^0.183.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@rspack/cli": "^1.7.7",
    "@rspack/core": "^1.7.7",
    "@rspack/plugin-react-refresh": "^1.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "jsdom": "^28.1.0",
    "react-refresh": "^0.18.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@bufbuild/protobuf": "2.11.0",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-web": "2.1.1"
  }
}
